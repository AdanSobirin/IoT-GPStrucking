# Copy file ini menjadi ".env" lalu sesuaikan nilainya.
# Dipakai bersama oleh api/*.php (PHP) dan backend/main.py (FastAPI).
# JANGAN commit file ".env" (hanya ".env.example" yang boleh di-commit).

# ── Database PostgreSQL (dipakai PHP via config.php) ──
DB_HOST=localhost
DB_PORT=5432
DB_NAME=db_sawit_app
DB_USER=postgres
DB_PASS=admin

# ── Database PostgreSQL (dipakai FastAPI, format connection string) ──
DATABASE_URL=postgresql://postgres:admin@localhost:5432/db_sawit_app

# ── Ukuran connection pool FastAPI ke PostgreSQL (kecilkan di VPS terbatas) ──
DB_POOL_MIN=1
DB_POOL_MAX=5

# ── CORS untuk API PHP (Android/ESP32 -> "*" aman karena bukan browser) ──
CORS_ALLOWED_ORIGIN=*

# ── CORS untuk FastAPI (dashboard React, harus daftar origin browser yang valid) ──
# Pisahkan dengan koma jika lebih dari satu origin.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Base URL publik aplikasi (dipakai untuk membangun URL foto di get_history.php) ──
APP_BASE_URL=http://localhost/dashboard1

# ── Interval polling dashboard React (ms). Naikkan untuk mengurangi beban server. ──
VITE_POLLING_INTERVAL_MS=8000

# ── URL server PHP tempat foto upload disimpan (dipakai ApprovalCenter untuk tampilkan foto) ──
# Harus sama dengan APP_BASE_URL di atas (host yang sama menjalankan api/*.php).
VITE_PHP_SERVER_URL=http://localhost/dashboard1

# ── Berat Janjang Rata-rata (kg per janjang) ──
# Dipakai backend untuk mengestimasi berat (Berat = Jumlah Janjang x BJR) di
# Driver Management & Approval Center, karena aplikasi belum terhubung ke
# timbangan asli. Sesuaikan dengan angka BJR aktual kebun Anda.
BJR_KG=22
